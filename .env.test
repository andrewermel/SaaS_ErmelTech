# Variáveis de ambiente para testes locais
# Aponta para o PostgreSQL de TESTE no Docker (porta 5433)
# Credenciais separadas do banco de desenvolvimento (porta 5432)
# Certificar que o Docker está rodando: docker compose up -d postgres-test
DATABASE_URL=postgresql://test:test@localhost:5433/test_db
JWT_SECRET=test-secret-key-for-ci
NODE_ENV=test
